{
  "manifest_version": 3,
  "name": "Client Message Assistant",
  "description": "Draft clear, professional client replies for independent professionals.",
  "version": "0.3.0",
  "action": {
    "default_title": "Client Message Assistant",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.svg",
      "32": "icons/icon.svg",
      "48": "icons/icon.svg",
      "128": "icons/icon.svg"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "permissions": [
    "activeTab",
    "contextMenus",
    "identity",
    "scripting",
    "storage",
    "tabs"
  ],
  "options_page": "options.html",
  "commands": {
    "open-assistant": {
      "suggested_key": {
        "default": "Alt+Shift+M"
      },
      "description": "Open the inline client message assistant"
    }
  }
}
